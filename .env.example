# AdityaRaj Capital Admin Dashboard - Environment Variables
# Copy this file to .env and update the values

# API Base URL
# For local development: http://localhost:3000
# For production: https://api.adityarajcapital.com
VITE_API_BASE_URL=http://localhost:3000

# Storage Base URL (Optional)
# Used for resolving payment proof file paths to viewable URLs
# Example: https://storage.googleapis.com/bucket-name
# If not set, the app will use payment_proof_url from API response (if available)
VITE_STORAGE_BASE_URL=

# Legacy admin login toggle (cutover only)
# When "true", the admin login screen exposes a toggle to use the legacy
# /api/admin/login endpoint with admin_id+password instead of /api/staff/login.
# Leave "false" once all super-admins have a Staff RBAC account; the legacy
# endpoint is scheduled for removal in backend Phase 4.
VITE_ENABLE_LEGACY_ADMIN_LOGIN=false
